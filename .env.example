# Copy this file to .env and fill in your actual keys.
# Never commit .env to git.

# Required — OpenRouter API key for LLM calls
# Get one free at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Optional — Groq API key for cloud Whisper STT
# Faster than local, free tier available at https://console.groq.com
# If left empty, falls back to local faster-whisper (downloads ~140 MB first run)
GROQ_API_KEY=gsk_...
